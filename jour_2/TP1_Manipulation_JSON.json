      "parameters": {
        "jsCode": "const items = $input.all();\nconst total_ttc = items.reduce((sum, item) => sum + item.json.montant_ttc, 0);\nconst commandes_importantes = items.filter(item => item.json.priorite === \"Haute\").length;\nreturn {\njson: {\nnombre_commandes: items.length,\nmontant_total_ttc: total_ttc.toFixed(2),\ncommandes_importantes: commandes_importantes,\ncommandes_standard: items.length - commandes_importantes,\nmontant_moyen: (total_ttc / items.length).toFixed(2)\n}\n};"
