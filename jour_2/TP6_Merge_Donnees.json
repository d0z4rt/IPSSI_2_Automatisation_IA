    {
      "parameters": {
        "jsCode": "const clientStats = []\n\nfor (const item of $input.all()) {\n  const current = item.json\n  let prevClientIndex = clientStats.findIndex(c => c.client_id === current.client_id)\n  if (prevClientIndex === -1) {\n    clientStats.push({client_id: current.client_id, ca_annuel: current.ca_annuel, nom: current.nom, secteur: current.secteur, nombre_commandes: current.commande_id ? 1 : 0, total_commandes: current.montant || 0 })\n    continue\n  }\n  \n  clientStats[prevClientIndex] = {\n    ...clientStats[prevClientIndex],\n    nombre_commandes: clientStats[prevClientIndex].nombre_commandes + 1,\n    total_commandes: clientStats[prevClientIndex].total_commandes + current.montant \n  }\n}\n\nreturn clientStats.map(c => {\n  const panierMoyen = c.nombre_commandes > 0 ? c.total_commandes / c.nombre_commandes  : 0;\n\n  return {\n    json: {...c,\n    panier_moyen: Math.round(panierMoyen),\n    taux_conversion: `${((c.total_commandes / c.ca_annuel) * 100).toFixed(2)}%`}\n  }\n});\n"
      },
      "type": "n8n-nodes-base.code",
