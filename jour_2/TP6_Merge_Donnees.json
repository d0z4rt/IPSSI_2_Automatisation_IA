    {
      "parameters": {
        "jsCode": "const items = $input.all().map(item => item.json);\nconst totalCA = items.reduce((sum, item) => sum + item.total_commandes, 0);\nconst clientsPremium = items.filter(item => item.total_commandes > 15000).length;\nreturn {\njson: {\ndate_rapport: new Date().toISOString(),\nnombre_clients: items.length,\nclients_premium: clientsPremium,\nchiffre_affaires_total: totalCA,\npanier_moyen_global: Math.round(totalCA / items.reduce((sum, item) => sum + item.nombre_commandes, 0)),\ndetails_clients: items\n}\n};"
