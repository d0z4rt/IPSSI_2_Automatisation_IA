    {
      "parameters": {
        "jsCode": "const items = $input.all().map(item => item.json);\nitems.sort((a, b) => b.score_activite - a.score_activite);\nreturn items.map((item, index) => ({\n  json: {\nclassement: index + 1,\n...item\n}\n}));"
      },
      "type": "n8n-nodes-base.code",
