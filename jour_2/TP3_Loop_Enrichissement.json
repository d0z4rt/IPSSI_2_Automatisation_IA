      "id": "5c90120e-c1aa-4534-80f6-ceba02ecb125",
      "name": "Sort by score"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json;\nconst score = (data.repos_publics * 2) + (data.followers * 0.5);\nconst niveau = score > 100 ? \"Expert\" :\nscore > 50 ? \"Intermédiaire\" :\n\"Débutant\";\nreturn {\njson: {\n...data,\nscore_activite: Math.round(score),\nniveau_activite: niveau\n}\n};"
      },
