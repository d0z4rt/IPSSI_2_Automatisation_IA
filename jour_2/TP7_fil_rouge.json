    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const candidature = $input.item.json;\n\nconst id = 'CAND-' + Date.now() + '-' + Math.random().toString(36).substring(2, 8).toUpperCase();\n\nconst dateReception = new Date();\nlet delaiTraitement = 0;\nswitch(candidature.categorie) {\n  case 'Candidat prioritaire':\n    delaiTraitement = 2;\n    break;\n  case 'Candidat à évaluer':\n    delaiTraitement = 5;\n    break;\n  default:\n    delaiTraitement = 10;\n}\nreturn {\n  json: {\n    ...candidature,\n    candidature_id: id,\n    date_reception: dateReception.toISOString(),\n    delai_traitement_jours: delaiTraitement,\n    date_traitement_limite: new Date(dateReception.getTime() + delaiTraitement * 24 * 60 * 60 * 1000).toISOString(),\n    status: 'en attente' \n  }\n};"
      },
