    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $input.item.json\nconst stats = {\n  total_candidatures: data.score.length,\n  \n  score_moyen: Math.round(data.score.reduce((a, b) => a + b, 0) / data.score.length * 10) / 10,\n  experience_moyenne: data.annees_experience.reduce((a, b) => a + b, 0) / data.annees_experience.length,\n  \n  score_min: Math.min(...data.score),\n  score_max: Math.max(...data.score),\n  \n  repartition_categories: {},\n  \n  scores_par_categorie: {}\n};\n\ndata.categorie.forEach(cat => {\n  stats.repartition_categories[cat] = (stats.repartition_categories[cat] || 0) + 1;\n});\n\ndata.categorie.forEach((cat, index) => {\n  if (!stats.scores_par_categorie[cat]) {\n    stats.scores_par_categorie[cat] = [];\n  }\n  stats.scores_par_categorie[cat].push(data.score[index]);\n});\n\nreturn {\n  json: stats\n};"
      },
      "type": "n8n-nodes-base.code",
